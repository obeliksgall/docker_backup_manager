{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BackupManagerConfig",
  "type": "object",
  "properties": {
    "settings": {
      "type": "object",
      "properties": {
        "rclone_flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["rclone_flags"]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "next_task_id": {"type": ["integer", "null"]},
          "source": {"type": "string"},
          "destination": {"type": "string"},
          "type": {"type": "string", "enum": ["local", "cloud"]},
          "mode": {"type": "string", "enum": ["mirror", "copy", "move"]},
          "schedule": {"type": "string"},
          "enabled": {"type": "boolean"},
          "restore_enabled": {"type": "boolean"},
          "exclude": {
            "type": "array",
            "items": {"type": "string"}
          },
          "custom_flags": {
            "type": "array",
            "items": {"type": "string"}
          },
          "retention_days": {"type": "integer", "minimum": 0},
          "status": {"type": ["string", "null"]},
          "discord_webhook": {"type": ["string", "null"]},
          "ntfy_url": {"type": ["string", "null"]},
          "email_enabled": {"type": "boolean"},
          "email_recipients": {"type": ["string", "null"]},
          "email_level": {"type": "string", "enum": ["wszystkie", "bledy_i_onedrive", "tylko_bledy"]},
		  "last_run": {"type": ["string", "null"]}
        },
        "required": [
          "id", 
          "name", 
          "source", 
          "destination", 
          "type", 
          "mode", 
          "schedule", 
          "enabled", 
          "restore_enabled", 
          "exclude", 
          "retention_days",
          "email_enabled",
          "email_level"
        ]
      }
    },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "username": {"type": "string"},
          "password": {"type": "string"}
        },
        "required": ["username", "password"]
      }
    }
  },
  "required": ["tasks"]
}